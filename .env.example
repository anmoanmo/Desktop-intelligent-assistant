# 根目录应用配置。复制为 .env 后按本机环境修改，不要提交 .env。

# DeepSeek 或其他 OpenAI 兼容聊天接口所需密钥
DEEPSEEK_API_KEY=sk-your-key

# 大模型设置
DESKTOP_ASSISTANT_LLM_PROVIDER=deepseek
DESKTOP_ASSISTANT_LLM_BASE_URL=https://api.deepseek.com
DESKTOP_ASSISTANT_LLM_MODEL=deepseek-v4-pro
DESKTOP_ASSISTANT_LLM_API_KEY_ENV=DEEPSEEK_API_KEY
DESKTOP_ASSISTANT_LLM_TEMPERATURE=0.4
DESKTOP_ASSISTANT_LLM_TIMEOUT_SECONDS=60

# 角色模型来源目录。macOS/Linux 多目录用冒号分隔，Windows 多目录用分号分隔。
DESKTOP_ASSISTANT_MODEL_DIRS=./Ark-Models-main
# 可选 TOML 模型来源文件。留空可避免绑定本机配置。
DESKTOP_ASSISTANT_MODEL_SOURCES_FILE=

# 本地运行状态路径。这些是路径配置，不是密钥。
DESKTOP_ASSISTANT_PERSONA_PATH=data/persona.toml
DESKTOP_ASSISTANT_MEMORY_ENABLED=true
DESKTOP_ASSISTANT_MEMORY_PATH=data/memory.json
DESKTOP_ASSISTANT_AUDIT_LOG=logs/tool_calls.jsonl

# 主动提醒设置。建议保持低频，避免打扰。
DESKTOP_ASSISTANT_AUTONOMY_ENABLED=true
DESKTOP_ASSISTANT_AUTONOMY_INTERVAL_SECONDS=180
DESKTOP_ASSISTANT_AUTONOMY_COOLDOWN_SECONDS=600

# 桌面上下文与隐私
DESKTOP_ASSISTANT_CONTEXT_MODE=manual
DESKTOP_ASSISTANT_OCR_ENABLED=false
DESKTOP_ASSISTANT_OCR_LANGUAGES=zh-Hans:en-US
DESKTOP_ASSISTANT_SEND_SCREENSHOTS=false

# 界面设置
DESKTOP_ASSISTANT_UI_LANGUAGE=zh-CN
DESKTOP_ASSISTANT_UI_WIDTH=420
DESKTOP_ASSISTANT_UI_HEIGHT=680
DESKTOP_ASSISTANT_AVATAR_X=0
DESKTOP_ASSISTANT_AVATAR_Y=0
DESKTOP_ASSISTANT_AVATAR_SCALE=1.0
